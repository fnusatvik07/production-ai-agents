# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXX   # used for embeddings

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=lsv2_pt_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
LANGSMITH_PROJECT=graphrag-research-engine
LANGCHAIN_TRACING_V2=true

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# ── Vector Store (Chroma) ──────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Redis (caching) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
EMBEDDING_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92

# ── PostgreSQL (LangGraph checkpointing) ──────────────────────────────────────
POSTGRES_URI=postgresql://graphrag:graphrag_pass@localhost:5432/graphrag

# ── Retrieval Config ──────────────────────────────────────────────────────────
HYBRID_SEARCH_TOP_K=20
RERANKER_TOP_K=5
DRIFT_MAX_HOPS=3
DRIFT_COMMUNITY_TOP_K=3
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7

# ── Evaluation ────────────────────────────────────────────────────────────────
CI_FAIL_ON_FAITHFULNESS_BELOW=0.80
EVAL_LLM_MODEL=gpt-4o

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=2
