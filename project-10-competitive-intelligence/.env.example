# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXX  # optional alternative

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=lsv2_pt_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
LANGSMITH_PROJECT=competitive-intelligence-swarm
LANGCHAIN_TRACING_V2=true

# ── Browser MCP ───────────────────────────────────────────────────────────────
BROWSER_MCP_URL=http://localhost:9100/mcp
BROWSER_MCP_PORT=9100

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8010

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULE_DAY_OF_WEEK=mon           # Run every Monday
SCHEDULE_HOUR=8                     # 8 AM
COMPETITORS=competitor-a.com,competitor-b.io   # comma-separated default list

# ── Notification (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
EMAIL_RECIPIENTS=team@yourcompany.com
